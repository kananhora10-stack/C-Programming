//Write a c++ program that takes two input integer and an operator as an input from the user. Perform the corresponding arithmetic operator on those number withput using if-else statement.

#include <iostream>
using namespace std;

int main() {
    int a, b;
    char op;

    cout << "Enter two integers: ";
    cin >> a >> b;

    cout << "Enter an operator (+, -, *, /, %): ";
    cin >> op;

    switch(op) {
        case '+':
            cout << "Result: " << a + b << endl;
            break;
        case '-':
            cout << "Result: " << a - b << endl;
            break;
        case '*':
            cout << "Result: " << a * b << endl;
            break;
        case '/':
            if(b != 0)
                cout << "Result: " << a / b << endl;
            else
                cout << "Division by zero not allowed" << endl;
            break;
        case '%':
            if(b != 0)
                cout << "Result: " << a % b << endl;
            else
                cout << "Modulo by zero not allowed" << endl;
            break;
        default:
            cout << "Invalid operator" << endl;
    }

    return 0;
}
// input; two integer= 24,30 ; operator= %
// output; 24

//Write a c++ program that takes two input integer from the user. Swap their value using temporary variable and print the updated value.

#include <iostream>
using namespace std;

int main() {
    int a, b, temp;

    cout << "Enter two integers: ";
    cin >> a >> b;

    temp = a;
    a = b;
    b = temp;

    cout << "After swapping:" << endl;
    cout << "a = " << a << endl;
    cout << "b = " << b << endl;

    return 0;
}
//input; 45,56
// output; after swapping: a=56, b=45

