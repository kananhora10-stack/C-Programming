// Create a college management system. in that a single parent class of college extended with a student and teacher class.
teacher= name,age; student= roll no,email-id,subject,batch, course; teacher=department,salary
call a virtual function to show their classes.

#include <iostream>
#include <string>
using namespace std;

// Parent Class
class College
{
protected:
    string name;
    int age;

public:
    College(string n, int a)
    {
        name = n;
        age = a;
    }

    // Virtual Function
    virtual void showDetails()
    {
        cout << "College Member Details" << endl;
    }

    // Pure Virtual Function (implemented by child classes)
    virtual void showClass() = 0;
};

// Student Class
class Student : public College
{
private:
    int rollNo;
    string email;
    string subject;
    string batch;
    string course;

public:
    Student(string n, int a, int r, string e,
            string s, string b, string c)
        : College(n, a)
    {
        rollNo = r;
        email = e;
        subject = s;
        batch = b;
        course = c;
    }

    void showDetails() override
    {
        cout << "\n--- Student Details ---" << endl;
        cout << "Name      : " << name << endl;
        cout << "Age       : " << age << endl;
        cout << "Roll No   : " << rollNo << endl;
        cout << "Email ID  : " << email << endl;
        cout << "Subject   : " << subject << endl;
        cout << "Batch     : " << batch << endl;
        cout << "Course    : " << course << endl;
    }

    // Implementing Pure Virtual Function
    void showClass() override
    {
        cout << "Student attends " << subject << " class." << endl;
    }
};

// Teacher Class
class Teacher : public College
{
private:
    string department;
    double salary;

public:
    Teacher(string n, int a, string d, double s)
        : College(n, a)
    {
        department = d;
        salary = s;
    }

    void showDetails() override
    {
        cout << "\n--- Teacher Details ---" << endl;
        cout << "Name       : " << name << endl;
        cout << "Age        : " << age << endl;
        cout << "Department : " << department << endl;
        cout << "Salary     : " << salary << endl;
    }

    // Implementing Pure Virtual Function
    void showClass() override
    {
        cout << "Teacher teaches in " << department << " department." << endl;
    }
};

// Main Function
int main()
{
    Student s1("Rahul", 20, 101,
               "rahul@gmail.com",
               "Maths", "2024",
               "BCA");

    Teacher t1("Sharma Sir", 40,
               "Computer Science", 50000);

    // Calling Virtual Functions
    s1.showDetails();
    s1.showClass();

    t1.showDetails();
    t1.showClass();

    return 0;
}
