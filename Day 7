// inheritance

#include<iostream>

using namespace std;
// base class or parent class
class Player
{
    public:
    string name;
    int runs;
    
    void setName(string n)
    {
        name = n;
    }
    void setRuns(int r)
    {
        runs = r;
    }
};
// Derived class or child class
class Cricketer : public Player
{
    public:
    string country;
    Cricketer(string s)
    {
        country = s;
    }
void show()
{
    cout<< "Name:"<< name<<endl;
    cout<< "Runs:"<< runs<< endl;
    cout<< "Country:"<< country<<endl;
}
};
int main()
{
    int runs;
    cin >> runs;
    Cricketer c1("India");
    c1.setName("Virat Kohli");
    c1.setRuns(runs);
    c1.show();
    return 0;
}

